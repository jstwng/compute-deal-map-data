{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/jstwng/compute-deal-map-data/schema/company.schema.json",
  "title": "Company",
  "type": "object",
  "required": ["slug", "name", "category"],
  "additionalProperties": false,
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Stable kebab-case ID used as foreign key from deals"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "ticker": {
      "type": ["string", "null"]
    },
    "category": {
      "type": "string",
      "enum": ["chip_designer", "hyperscaler", "neocloud", "ai_lab", "data_center", "investor", "memory", "foundry", "networking", "server_oem", "power", "equipment", "packaging"]
    },
    "subline": {
      "type": "string"
    },
    "acquired": {
      "type": "boolean",
      "default": false
    }
  }
}
