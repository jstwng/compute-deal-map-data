{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/jstwng/compute-deal-map-data/schema/deal.schema.json",
  "title": "Deal",
  "type": "object",
  "required": [
    "id", "source_slug", "source_name", "target_slug", "target_name",
    "deal_type", "date", "date_display", "description", "source_url"
  ],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "source_slug": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "source_name": { "type": "string", "minLength": 1 },
    "target_slug": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "target_name": { "type": "string", "minLength": 1 },
    "deal_type": {
      "type": "string",
      "enum": ["gpu_purchase", "custom_asic", "equity_investment", "cloud_capacity", "m_and_a", "funding_round", "power_ppa"]
    },
    "value_billions": { "type": ["number", "null"], "minimum": 0 },
    "value_display": { "type": ["string", "null"] },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}(-\\d{2})?$" },
    "date_display": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "source_url": { "type": "string", "format": "uri", "pattern": "^https://" }
  }
}
